---
/**
 * Galeria realizacji — siatka zdjęć z opcją "Pokaż więcej"
 *
 * JAK DODAWAĆ ZDJĘCIA:
 *   1. Wrzuć zdjęcia do folderu:  src/assets/galeria/
 *   2. Dowolne nazwy plików       (np. parkiet-1.jpg, salon-3.jpg)
 *   3. Astro automatycznie:       konwertuje do WebP, kompresuje,
 *                                 tworzy srcset, dodaje lazy loading
 *
 * Obsługiwane formaty: .jpg, .jpeg, .png, .webp, .avif
 */
import { Image } from 'astro:assets';

export interface Props {
  /** Ile zdjęć pokazać na starcie (reszta ukryta za przyciskiem) */
  initialShow?: number;
  /** Maksymalna liczba zdjęć (brak = wszystkie) */
  limit?: number;
  /** Czy pokazać link do /realizacje */
  showLink?: boolean;
}

const { initialShow = 6, limit, showLink = true } = Astro.props;

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/galeria/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

const allImages = Object.values(modules).map((mod) => mod.default);
const images = limit ? allImages.slice(0, limit) : allImages;
const hasImages = images.length > 0;
const hasMore = images.length > initialShow;
const galleryId = 'gallery-' + Math.random().toString(36).slice(2, 8);
---

<div>
  {hasImages ? (
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" id={galleryId}>
      {images.map((img, i) => (
        <div
          class:list={[
            'gallery-item bg-stone-100 aspect-square',
            i >= initialShow && 'gallery-hidden'
          ]}
          data-animate
          style={`transition-delay: ${Math.min(i * 60, 400)}ms`}
        >
          <Image
            src={img}
            alt={`Cyklinowanie bezpyłowe parkietu – realizacja nr ${i + 1} – Książczak Parkiety Siedlce`}
            width={1200}
            height={1200}
            class="w-full h-full object-cover gallery-image-click"
            loading={i < 4 ? 'eager' : 'lazy'}
            format="webp"
            quality={82}
          />
        </div>
      ))}
    </div>
  ) : (
    <div class="rounded-2xl bg-white p-10 text-center ring-1 ring-stone-100">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-stone-100">
        <svg class="h-8 w-8 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
        </svg>
      </div>
      <p class="mt-4 text-sm font-semibold text-stone-700">Zdjęcia pojawią się tutaj</p>
      <p class="mt-1 text-xs text-stone-400">
        Wrzuć zdjęcia do <code class="rounded bg-stone-100 px-1 py-0.5">src/assets/galeria/</code>
      </p>
    </div>
  )}

  {hasMore && (
    <div class="mt-8 text-center">
      <button
        class="btn-secondary gallery-show-more"
        data-gallery={galleryId}
        type="button"
      >
        Pokaż więcej
        <svg class="h-4 w-4 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    </div>
  )}

  {showLink && (
    <div class="mt-8 text-center">
      <a href="/realizacje" class="btn-secondary">
        Zobacz wszystkie realizacje
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  )}
</div>

<style is:global>
  .gallery-hidden {
    display: none;
  }
  .gallery-reveal {
    display: block;
    animation: galleryFadeIn .5s cubic-bezier(.16,1,.3,1) both;
  }
  @keyframes galleryFadeIn {
    from { opacity: 0; transform: translateY(20px) scale(.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
</style>

<script is:inline>
  document.addEventListener('click', function(e) {
    const btn = e.target.closest('.gallery-show-more');
    if (!btn) return;
    const gridId = btn.getAttribute('data-gallery');
    const grid = document.getElementById(gridId);
    if (!grid) return;

    const hidden = grid.querySelectorAll('.gallery-hidden');
    hidden.forEach(function(el, i) {
      el.classList.remove('gallery-hidden');
      el.classList.add('gallery-reveal');
      el.style.animationDelay = (i * 60) + 'ms';
      // trigger in-view for data-animate
      el.classList.add('in-view');
    });

    // re-init lightbox so new images are clickable
    if (typeof initLightbox === 'function') initLightbox();

    btn.parentElement.remove();
  });
</script>
