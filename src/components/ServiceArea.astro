---
const cities = [
  { name: "Siedlce", primary: true, desc: "Siedziba firmy" },
  { name: "Warszawa", primary: true, desc: "~100 km" },
  { name: "Mińsk Mazowiecki", primary: false, desc: "~60 km" },
  { name: "Łuków", primary: false, desc: "~40 km" },
  { name: "Sokołów Podlaski", primary: false, desc: "~40 km" },
  { name: "Biała Podlaska", primary: false, desc: "~80 km" },
  { name: "Garwolin", primary: false, desc: "~70 km" },
  { name: "Ostrów Mazowiecka", primary: false, desc: "~80 km" },
  { name: "Węgrów", primary: false, desc: "~30 km" },
  { name: "Mordy", primary: false, desc: "~25 km" },
];
---

<section
  class="section-padding bg-white"
  id="obszar"
  aria-labelledby="area-heading"
>
  <div class="container-max">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Text -->
      <div>
        <h2 class="section-title" id="area-heading">Obszar działania</h2>
        <p class="section-subtitle max-w-lg">
          Obsługujemy <strong>Siedlce i okolice w promieniu 150 km</strong>.
          Regularnie pracujemy też na terenie <strong
            >Warszawy i całego Mazowsza</strong
          >.
        </p>

        <div class="mt-8 flex flex-wrap gap-2">
          {
            cities.map((city) => (
              <span
                class={`inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium ${
                  city.primary
                    ? "bg-wood-500 text-white"
                    : "bg-stone-100 text-stone-700"
                }`}
              >
                {city.name}
                {city.primary && (
                  <span class="ml-1.5 text-xs opacity-75">★</span>
                )}
              </span>
            ))
          }
          <span
            class="inline-flex items-center rounded-full bg-stone-50 px-3 py-1.5 text-sm text-stone-500 ring-1 ring-dashed ring-stone-300"
          >
            + okolice...
          </span>
        </div>
      </div>

      <!-- Google Maps – lazy loaded via IntersectionObserver (saves ~350 KB JS on load) -->
      <div
        id="map-container"
        class="overflow-hidden rounded-2xl shadow-md ring-1 ring-stone-100 h-80 lg:h-96 bg-stone-100 flex items-center justify-center"
      >
        <svg class="h-10 w-10 text-stone-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
      </div>
      <script is:inline>
        (function () {
          var c = document.getElementById('map-container');
          if (!c) return;
          var done = false;
          function load() {
            if (done) return; done = true;
            var f = document.createElement('iframe');
            f.src = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2444.762608617142!2d22.522501477069145!3d52.21136137198201!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xa9e14da7f4ba4b07%3A0x3d7acf69497a4821!2sKsi%C4%85%C5%BCczak%20Parkiety%20i%20Schody%20%7C%20Cyklinowanie%20i%20uk%C5%82adanie%20pod%C5%82%C3%B3g%20drewnianych!5e0!3m2!1spl!2spl!4v1774719026645!5m2!1spl!2spl';
            f.width = '100%'; f.height = '100%';
            f.style.border = '0';
            f.allowFullscreen = true;
            f.referrerPolicy = 'no-referrer-when-downgrade';
            f.title = 'Ksi\u0105\u017Cczak Parkiety i Schody \u2013 lokalizacja na mapie';
            c.innerHTML = ''; c.appendChild(f);
          }
          if ('IntersectionObserver' in window) {
            new IntersectionObserver(function (entries, obs) {
              if (entries[0].isIntersecting) { load(); obs.disconnect(); }
            }, { rootMargin: '200px' }).observe(c);
          } else { load(); }
        })();
      </script>
    </div>
  </div>
</section>
