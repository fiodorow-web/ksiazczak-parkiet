---
import Layout from '../layouts/Layout.astro';
import ContactCTA from '../components/ContactCTA.astro';
import FAQ from '../components/FAQ.astro';
import { localBusinessSchema } from '../components/SchemaOrg.astro';
import { CONTACT } from '../config';
import { Image } from 'astro:assets';

const schodMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/schody/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
const schodArr = Object.values(schodMods).map(m => m.default);
const schodHero = schodArr[0] ?? null;

const PHONE = CONTACT.phone;
const PHONE_HREF = CONTACT.phoneHref;

const stairsSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Schody drewniane – montaż, produkcja, renowacja',
  description:
    'Produkcja, montaż i renowacja schodów drewnianych. Siedlce i okolice. Ponad 25 lat doświadczenia.',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Książczak Parkiety i Schody',
    '@id': 'https://ksiazczak-parkiet.pl/#business',
  },
  areaServed: [
    { '@type': 'City', name: 'Siedlce' },
    { '@type': 'City', name: 'Warszawa' },
    { '@type': 'State', name: 'Mazowieckie' },
  ],
};
---

<Layout
  title="Schody Drewniane Siedlce – Montaż, Produkcja, Renowacja | Książczak"
  description="Schody drewniane – montaż, produkcja i renowacja. Siedlce, Warszawa i okolice. Ponad 25 lat doświadczenia. ☎ Bezpłatna wycena!"
  schema={[localBusinessSchema, stairsSchema]}
  breadcrumbs={[{ name: 'Schody drewniane', url: '/schody-drewniane' }]}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-stone-800 to-stone-900 py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 text-sm text-stone-400" aria-label="Breadcrumb">
          <ol class="flex items-center gap-1.5">
            <li><a href="/" class="hover:text-stone-200 transition-colors">Strona główna</a></li>
            <li>/</li>
            <li class="text-stone-300" aria-current="page">Schody drewniane</li>
          </ol>
        </nav>
        <h1 class="text-2xl font-bold leading-tight text-white sm:text-4xl" data-animate>
          Schody <span class="text-wood-400">drewniane</span><br/>
          Siedlce i okolice
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-stone-300" data-animate style="transition-delay: 100ms">
          Produkcja, montaż i renowacja schodów drewnianych. Ponad 25 lat doświadczenia. Siedlce, Warszawa i cały region mazowiecki.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={PHONE_HREF} class="btn-primary text-base py-4 px-7">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            Zadzwoń: {PHONE}
          </a>
          <a href="/kontakt" class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/60 px-7 py-4 text-base font-semibold text-white transition-all hover:bg-white/10">
            Bezpłatna wycena
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- O nas -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="section-title" data-animate>Ponad 25 lat doświadczenia w schodach drewnianych</h2>
          <div class="mt-6 space-y-4 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            <p>
              Specjalizujemy się w <strong class="text-stone-900">projektowaniu i wykonywaniu schodów drewnianych</strong> od ponad 25 lat. Rodzinna firma Książczak kompleksowo obsługuje wszystkie potrzeby związane z drewnem w domu.
            </p>
            <p>
              Pracujemy z najwyższej jakości drewnem – dębem, jesionem, sosną i innymi gatunkami. Każde schody są projektowane i wykonywane <strong class="text-stone-900">na wymiar</strong> – pasują perfekcyjnie do każdego wnętrza.
            </p>
            <p>
              Obsługujemy Siedlce, Warszawę oraz cały region mazowiecki. Bezpłatna wycena i pomiary – przyjedziemy do Ciebie.
            </p>
          </div>
          <div class="mt-6 flex gap-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-wood-500">25+</div>
              <div class="text-xs text-stone-500">lat doświadczenia</div>
            </div>
            <div class="w-px bg-stone-200"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-wood-500">na wymiar</div>
              <div class="text-xs text-stone-500">każde schody</div>
            </div>
            <div class="w-px bg-stone-200"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-wood-500">150 km</div>
              <div class="text-xs text-stone-500">zasięg od Siedlec</div>
            </div>
          </div>
        </div>
        <div class="relative h-72 lg:h-96 overflow-hidden rounded-2xl bg-stone-100">
          {schodHero && <Image src={schodHero} alt="Schody drewniane – Książczak Siedlce" class="w-full h-full object-cover" width={600} height={400} loading="lazy" format="webp" quality={82} />}
          {!schodHero && <div class="absolute inset-0 flex items-center justify-center text-stone-400 text-sm">Zdjęcie schodów</div>}
        </div>
      </div>
    </div>
  </section>

  <!-- Usługi schodowe -->
  <section class="section-padding bg-stone-50">
    <div class="container-max">
      <h2 class="section-title text-center" data-animate>Co oferujemy?</h2>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            icon: '<path d="M22 9.67l-2-1.33V4a1 1 0 00-1-1h-3a1 1 0 00-1 1v.67L12 3 2 9.67V21h8v-6h4v6h8V9.67z"/>',
            title: 'Produkcja schodów',
            desc: 'Schody drewniane wykonane na wymiar – od projektu po gotowy produkt. Dąb, jesion, sosna, buk i inne gatunki.',
          },
          {
            icon: '<path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>',
            title: 'Montaż schodów',
            desc: 'Profesjonalny montaż nowych schodów drewnianych w każdym budownictwie – domy nowe i remonty.',
          },
          {
            icon: '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>',
            title: 'Renowacja schodów',
            desc: 'Renowacja starych, zniszczonych schodów – szlifowanie, naprawa stopni, lakierowanie lub olejowanie.',
          },
          {
            icon: '<path d="M3 3h18v2H3V3zm0 16h18v2H3v-2zm0-8h18v2H3v-2zm4-4h10v2H7V7zm0 8h10v2H7v-2z"/>',
            title: 'Balustrady',
            desc: 'Drewniane balustrady i poręcze dopasowane do charakteru schodów i wnętrza.',
          },
          {
            icon: '<path d="M7 21H3a1 1 0 01-1-1v-4a1 1 0 011-1h4v6zm7-2H10v-4h4v4zm7 2h-5v-6h4a1 1 0 011 1v4a1 1 0 01-1 1zM12 3l-8 6h4v8h8v-8h4L12 3z"/>',
            title: 'Wykończenie',
            desc: 'Lakierowanie lub olejowanie schodów – trwałe, odporne na ścieranie powłoki.',
          },
          {
            icon: '<path d="M20 2H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM9 18H7V9h2v9zm4 0h-2V6h2v12zm4 0h-2v-5h2v5z"/>',
            title: 'Bezpłatne pomiary',
            desc: 'Dojedziemy na miejsce, zmierzymy i wycenimy bez żadnych zobowiązań.',
          },
        ].map((item, i) => (
          <article data-animate style={`transition-delay: ${i * 80}ms`} class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-stone-100">
            <svg class="h-8 w-8 text-wood-500 mb-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><Fragment set:html={item.icon} /></svg>
            <h3 class="text-base font-bold text-stone-900">{item.title}</h3>
            <p class="mt-2 text-sm text-stone-600 leading-relaxed">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <h2 class="section-title text-center" data-animate>Realizacje – schody drewniane</h2>
      {schodArr.length > 0 && (
      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3">
        {schodArr.slice(0, 6).map((img, i) => (
          <div class="overflow-hidden rounded-xl bg-stone-100 aspect-square">
            <Image
              src={img}
              alt={`Schody drewniane – realizacja ${i + 1} – Siedlce i okolice`}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              width={400}
              height={400}
              loading="lazy"
              format="webp"
              quality={82}
            />
          </div>
        ))}
      </div>
      )}
      <p class="mt-6 text-center text-sm text-stone-500">
        Więcej realizacji dostępnych na życzenie. <a href="/kontakt" class="text-wood-600 font-medium hover:underline">Skontaktuj się z nami →</a>
      </p>
    </div>
  </section>

  <FAQ items={[
    { q: 'Z jakiego drewna wykonujecie schody?', a: 'Pracujemy z dębem, jesionem, sosną, bukiem i innymi gatunkami drewna. Dąb to najczęstszy wybór – twardy, odporny i pięknie wyglądający. Pomagamy dobrać gatunek do wnętrza i budżetu.' },
    { q: 'Ile kosztują schody drewniane na zamówienie?', a: 'Cena zależy od gatunku drewna, wymiarów, rodzaju schodów (proste, kręte, zabiegowe) i wykończenia. Bezpłatna wycena po pomiarach na miejscu – przyjedziemy do Ciebie w Siedlcach, Warszawie i okolicach.' },
    { q: 'Jak długo trwa wykonanie schodów drewnianych?', a: 'Standardowy projekt – od pomiaru do montażu – trwa 4–8 tygodni, zależnie od złożoności i kolejki zleceń. Schody proste realizujemy szybciej niż kręte. Termin ustalamy indywidualnie.' },
    { q: 'Czy wykonujecie renowację starych schodów?', a: 'Tak. Zajmujemy się renowacją starych schodów – szlifowaniem, naprawą pękniętych stopni, wymianą uszkodzonych elementów oraz lakierowaniem lub olejowaniem. Często tańsze niż budowa nowych schodów.' },
    { q: 'Czy obsługujecie schody w całej Polsce?', a: 'Obsługujemy Siedlce, Warszawę oraz okolice w promieniu ok. 150 km – cały region mazowiecki. W przypadku większych zleceń możliwy dojazd dalej – zapytaj indywidualnie.' },
  ]} />

  <ContactCTA
    title="Zamów schody drewniane"
    subtitle="Bezpłatna wycena i pomiary w Siedlcach, Warszawie i okolicach. Zadzwoń – odpowiemy od ręki."
  />
</Layout>
