---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema } from '../components/SchemaOrg.astro';
import { Image } from 'astro:assets';

const schodMods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/schody/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
const schodArr = Object.values(schodMods).map(m => m.default);
const schodInitial = 8;
const schodHasMore = schodArr.length > schodInitial;
---

<Layout
  title="Realizacje – Galeria Podłóg i Schodów Drewnianych | Książczak Siedlce"
  description="Galeria realizacji cyklinowania bezpyłowego, lakierowania podłóg i renowacji schodów drewnianych. Siedlce, Warszawa, Mińsk Mazowiecki. Ponad 1000 zrealizowanych zleceń."
  schema={localBusinessSchema}
  breadcrumbs={[{ name: 'Realizacje', url: '/realizacje' }]}
>
  <!-- Header -->
  <section class="bg-stone-50 py-14 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-4 text-sm text-stone-400" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-stone-600 transition-colors">Strona główna</a></li>
          <li>/</li>
          <li class="text-stone-600" aria-current="page">Realizacje</li>
        </ol>
      </nav>
      <h1 class="text-2xl font-bold text-stone-900 sm:text-4xl" data-animate>Nasze realizacje</h1>
      <p class="mt-4 max-w-2xl text-lg text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
        Ponad 1000 zrealizowanych zleceń – cyklinowanie bezpyłowe, lakierowanie i olejowanie podłóg drewnianych oraz schody na wymiar. Każde zdjęcie to prawdziwa realizacja z naszym udziałem.
      </p>
    </div>
  </section>

  <!-- Galeria – podłogi -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <h2 class="section-title" data-animate>Podłogi drewniane</h2>
      <p class="mt-2 mb-8 text-stone-500" data-animate style="transition-delay: 60ms">Cyklinowanie bezpyłowe, lakierowanie, olejowanie i układanie parkietu.</p>
      <Gallery initialShow={12} showLink={false} />
    </div>
  </section>

  <!-- Galeria – schody -->
  <section class="section-padding bg-stone-50">
    <div class="container-max">
      <h2 class="section-title" data-animate>Schody drewniane</h2>
      <p class="mt-2 mb-8 text-stone-500" data-animate style="transition-delay: 60ms">Schody drewniane wykonane i odrestaurowane w Siedlcach i okolicach.</p>
      {schodArr.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4" id="schody-grid">
          {schodArr.map((img, i) => (
            <div
              class:list={[
                'gallery-item bg-stone-100 aspect-square',
                i >= schodInitial && 'gallery-hidden'
              ]}
              data-animate
              style={`transition-delay: ${Math.min(i * 60, 400)}ms`}
            >
              <Image
                src={img}
                alt={`Schody drewniane – realizacja ${i + 1}`}
                class="w-full h-full object-cover gallery-image-click"
                width={1200}
                height={1200}
                loading="lazy"
                format="webp"
                quality={82}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="text-stone-400 text-sm">Zdjęcia pojawią się wkrótce.</p>
      )}
      {schodHasMore && (
        <div class="mt-8 text-center">
          <button
            class="btn-secondary gallery-show-more"
            data-gallery="schody-grid"
            type="button"
          >
            Pokaż więcej
            <svg class="h-4 w-4 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>
      )}
    </div>
  </section>

  <ContactCTA
    title="Chcesz takie efekty?"
    subtitle="Najlepiej zadzwoń – odbieramy od ręki. Bezpłatna wycena w Siedlcach, Warszawie i okolicach."
  />
</Layout>
