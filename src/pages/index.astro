---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Gallery from '../components/Gallery.astro';
import ServiceArea from '../components/ServiceArea.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema, howToSchema, krzysztofSchema } from '../components/SchemaOrg.astro';
---

<Layout
  title="Cyklinowanie Bezpyłowe Siedlce, Warszawa, Mińsk Mazowiecki | Książczak Parkiety"
  description="Profesjonalne cyklinowanie bezpyłowe parkietów i podłóg drewnianych. Siedlce, Warszawa, Mińsk Mazowiecki i okolice. Ponad 25 lat doświadczenia. Bezpłatna wycena!"
  schema={[localBusinessSchema, howToSchema, krzysztofSchema]}
>
  <Hero />
  <Services />
  <HowItWorks />
  <section class="section-padding bg-stone-50" id="realizacje" aria-labelledby="gallery-heading">
    <div class="container-max">
      <div class="text-center">
        <h2 class="section-title" id="gallery-heading" data-animate>Nasze realizacje</h2>
        <p class="section-subtitle mx-auto max-w-xl" data-animate style="transition-delay: 80ms">
          Efekty naszej pracy mówią same za siebie. Ponad 1000 zrealizowanych zleceń.
        </p>
      </div>
      <div class="mt-10">
        <Gallery limit={4} showLink={true} />
      </div>
    </div>
  </section>
  <ServiceArea />

  <!-- Nasze miasta — wewnętrzne linkowanie SEO -->
  <section class="section-padding bg-stone-50" id="miasta" aria-labelledby="cities-heading">
    <div class="container-max">
      <div class="text-center">
        <h2 class="section-title" id="cities-heading" data-animate>Cyklinowanie w Twoim mieście</h2>
        <p class="section-subtitle mx-auto max-w-xl" data-animate style="transition-delay: 80ms">
          Obsługujemy Siedlce, Warszawę, Mińsk Mazowiecki i cały obszar Mazowsza. Sprawdź szczegóły dla swojego miasta.
        </p>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {[
          {
            miasto: 'Cyklinowanie Siedlce',
            slug: 'siedlce',
            opis: 'Nasz główny teren — dojazd gratis, wycena w 1–2 dni. Ponad 25 lat pracy w siedleckich blokach, kamienicach i domach.',
            badge: 'Siedziba firmy',
          },
          {
            miasto: 'Cyklinowanie Warszawa',
            slug: 'warszawa',
            opis: 'Regularnie w całej Warszawie. Kamienice, apartamentowce, jodełka angielska i francuska — znamy stołeczne podłogi.',
            badge: '~100 km',
          },
          {
            miasto: 'Cyklinowanie Mińsk Mazowiecki',
            slug: 'minsk-mazowiecki',
            opis: 'Na naszej stałej trasie Siedlce–Warszawa. Obsługujemy też Sulejówek, Halinów, Dębe Wielkie i cały powiat miński.',
            badge: '~60 km',
          },
        ].map((item, i) => (
          <a
            href={`/cyklinowanie-${item.slug}`}
            class="group rounded-2xl bg-white p-6 ring-1 ring-stone-100 shadow-sm transition-all hover:shadow-md hover:ring-wood-200"
            data-animate
            style={`transition-delay: ${160 + i * 80}ms`}
          >
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-base font-bold text-stone-900 group-hover:text-wood-600 transition-colors">{item.miasto}</h3>
              <span class="rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-600">{item.badge}</span>
            </div>
            <p class="text-sm leading-relaxed text-stone-600">{item.opis}</p>
            <p class="mt-3 text-sm font-medium text-wood-600 flex items-center gap-1">
              Zobacz szczegóły
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Reviews />
  <FAQ />
  <ContactCTA />
</Layout>
