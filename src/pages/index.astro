---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Gallery from '../components/Gallery.astro';
import ServiceArea from '../components/ServiceArea.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema, howToSchema, krzysztofSchema, andrzejSchema } from '../components/SchemaOrg.astro';
---

<Layout
  title="Cyklinowanie Bezpyłowe Podłóg Siedlce i Warszawa | Książczak Parkiety"
  description="Profesjonalne cyklinowanie bezpyłowe parkietów i podłóg drewnianych. Siedlce, Warszawa i okolice do 100 km. Ponad 25 lat doświadczenia. Bezpłatna wycena!"
  schema={[localBusinessSchema, howToSchema, krzysztofSchema, andrzejSchema]}
>
  <Hero />
  <Services />
  <HowItWorks />
  <section class="section-padding bg-stone-50" id="realizacje" aria-labelledby="gallery-heading">
    <div class="container-max">
      <div class="text-center">
        <h2 class="section-title" id="gallery-heading" data-animate>Nasze realizacje</h2>
        <p class="section-subtitle mx-auto max-w-xl" data-animate style="transition-delay: 80ms">
          Efekty naszej pracy mówią same za siebie. Ponad 1000 zrealizowanych zleceń.
        </p>
      </div>
      <div class="mt-10">
        <Gallery limit={6} showLink={true} />
      </div>
    </div>
  </section>
  <ServiceArea />
  <Reviews />
  <FAQ />
  <ContactCTA />
</Layout>
