---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { localBusinessSchema } from '../components/SchemaOrg.astro';
import { CONTACT, SITE } from '../config';
import { miasta } from '../data/miasta';
import type { Miasto } from '../data/miasta';

export function getStaticPaths() {
  return miasta.map((m) => ({
    params: { miasto: m.slug },
    props: { miasto: m },
  }));
}

interface Props {
  miasto: Miasto;
}

const { miasto } = Astro.props;
const PHONE = CONTACT.phone;
const PHONE_HREF = CONTACT.phoneHref;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Cyklinowanie bezpyłowe ${miasto.nazwa}`,
  description: `Profesjonalne cyklinowanie bezpyłowe podłóg drewnianych w ${miasto.nazwaOkolice}. Ponad 25 lat doświadczenia. Bezpłatna wycena.`,
  provider: {
    '@type': 'LocalBusiness',
    name: SITE.name,
    '@id': `${SITE.url}/#business`,
  },
  areaServed: {
    '@type': 'City',
    name: miasto.nazwa,
  },
};
---

<Layout
  title={`Cyklinowanie Bezpyłowe ${miasto.nazwa} – Bezpłatna Wycena | Książczak`}
  description={`Cyklinowanie bezpyłowe parkietów i podłóg drewnianych w ${miasto.nazwaOkolice}. Technologia bez pyłu, ponad 25 lat doświadczenia. ☎ Zadzwoń po bezpłatną wycenę!`}
  schema={[localBusinessSchema, serviceSchema]}
  breadcrumbs={[
    { name: 'Cyklinowanie bezpyłowe', url: '/cyklinowanie-bezpylowe' },
    { name: miasto.nazwa, url: `/cyklinowanie-${miasto.slug}` },
  ]}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-stone-900 to-stone-800 py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <nav class="mb-6 text-sm text-stone-400" aria-label="Breadcrumb">
          <ol class="flex items-center gap-1.5">
            <li><a href="/" class="hover:text-stone-200 transition-colors">Strona główna</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/cyklinowanie-bezpylowe" class="hover:text-stone-200 transition-colors">Cyklinowanie bezpyłowe</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-stone-300" aria-current="page">{miasto.nazwa}</li>
          </ol>
        </nav>

        <div
          data-animate
          class="mb-5 inline-flex items-center gap-2 rounded-full bg-wood-500/20 px-4 py-1.5 text-sm font-medium text-wood-300 ring-1 ring-wood-500/30"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          {miasto.nazwa} · {miasto.odleglosc}
        </div>

        <h1 class="text-2xl font-bold leading-tight text-white sm:text-4xl" data-animate style="transition-delay: 80ms">
          Cyklinowanie <span class="text-wood-400">bezpyłowe</span><br/>
          {miasto.nazwa}
        </h1>

        <p class="mt-6 text-base leading-relaxed text-stone-300 sm:text-lg" data-animate style="transition-delay: 160ms">
          {miasto.heroOpis}
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row" data-animate style="transition-delay: 240ms">
          <a href={PHONE_HREF} class="btn-primary text-base py-4 px-7">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            Zadzwoń: {PHONE}
          </a>
          <a href="/kontakt" class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/60 px-7 py-4 text-base font-semibold text-white transition-all hover:bg-white/10">
            Bezpłatna wycena
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Dlaczego my w tym mieście -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="section-title" data-animate>
            Dlaczego my w {miasto.nazwaOkolice}?
          </h2>
          <p class="mt-6 text-stone-600 leading-relaxed" data-animate style="transition-delay: 80ms">
            {miasto.opis}
          </p>
          <div class="mt-8 space-y-3" data-animate style="transition-delay: 160ms">
            {miasto.atuty.map((atut) => (
              <div class="flex items-start gap-3">
                <svg class="h-5 w-5 text-green-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                <span class="text-stone-700">{atut}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {miasto.korzysci.map((card, i) => (
            <div data-animate style={`transition-delay: ${i * 80}ms`} class="rounded-xl bg-stone-50 p-5 text-center ring-1 ring-stone-100">
              <svg class="mx-auto h-8 w-8 text-wood-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={card.icon} /></svg>
              <p class="mt-2 text-sm font-semibold text-stone-900">{card.title}</p>
              <p class="mt-1 text-xs text-stone-600 leading-snug">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Sekcja dodatkowa — unikalna per miasto -->
  <section class="section-padding bg-stone-50">
    <div class="container-max">
      <h2 class="section-title" data-animate>{miasto.sekcjaExtra.tytul}</h2>
      <div class="mt-8 max-w-3xl space-y-5 text-stone-600 leading-relaxed">
        {miasto.sekcjaExtra.tresc.map((p, i) => (
          <p data-animate style={`transition-delay: ${i * 80}ms`}>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Etapy pracy — unikalne opisy per miasto -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <h2 class="section-title text-center" data-animate>Jak pracujemy w {miasto.nazwaOkolice}?</h2>
      <div class="mt-10 space-y-6 max-w-2xl mx-auto">
        {miasto.etapy.map((step, i) => (
          <div class="flex gap-5" data-animate style={`transition-delay: ${i * 80}ms`}>
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-wood-500 text-sm font-bold text-white">{step.n}</div>
            <div class="pb-6 border-b border-stone-100 last:border-0 flex-1">
              <p class="font-semibold text-stone-900">{step.title}</p>
              <p class="mt-1 text-sm text-stone-600 leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Powiązane usługi — internal linking -->
  <section class="section-padding bg-white">
    <div class="container-max">
      <h2 class="section-title text-center" data-animate>Sprawdź pełną ofertę</h2>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3 max-w-3xl mx-auto">
        <a href="/uslugi" class="group rounded-xl bg-stone-50 p-5 text-center ring-1 ring-stone-100 transition-all hover:ring-wood-200 hover:shadow-sm" data-animate>
          <p class="font-semibold text-stone-900 group-hover:text-wood-600 transition-colors">Wszystkie usługi</p>
          <p class="mt-1 text-xs text-stone-500">Cyklinowanie, lakierowanie, olejowanie, układanie</p>
        </a>
        <a href="/schody-drewniane" class="group rounded-xl bg-stone-50 p-5 text-center ring-1 ring-stone-100 transition-all hover:ring-wood-200 hover:shadow-sm" data-animate style="transition-delay: 80ms">
          <p class="font-semibold text-stone-900 group-hover:text-wood-600 transition-colors">Schody drewniane</p>
          <p class="mt-1 text-xs text-stone-500">Montaż, produkcja i renowacja na wymiar</p>
        </a>
        <a href="/realizacje" class="group rounded-xl bg-stone-50 p-5 text-center ring-1 ring-stone-100 transition-all hover:ring-wood-200 hover:shadow-sm" data-animate style="transition-delay: 160ms">
          <p class="font-semibold text-stone-900 group-hover:text-wood-600 transition-colors">Realizacje</p>
          <p class="mt-1 text-xs text-stone-500">Galeria zdjęć parkietów i schodów</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ — unikalne pytania per miasto -->
  <FAQ items={miasto.faq} />

  <ContactCTA
    title={`Zamów cyklinowanie w ${miasto.nazwaOkolice}`}
    subtitle={`Najlepiej zadzwoń – odbieramy i odpowiadamy od ręki. Bezpłatna wycena w ${miasto.nazwaOkolice}.`}
  />
</Layout>
